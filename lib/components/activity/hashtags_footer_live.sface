{#if @hashtags != []}
  <div class="flex flex-wrap gap-1.5 mt-1">
    {#for tag <- @hashtags}
      <LinkLive
        to={~p"/hashtag/" <> e(tag, :named, :name, "")}
        class="badge badge-sm badge-primary badge-soft"
      >
        #{e(tag, :named, :name, "")}
      </LinkLive>
    {/for}
  </div>
{/if}
