  {#match "LGBTQ"}<#Icon iconify="ph:rainbow-duotone" class={[@class, @colored && "text-fuchsia-400"]} />
  {#match "MEETING"}<#Icon iconify="ph:users-duotone" class={[@class, @colored && "text-blue-400"]} />
  {#match "MEDITATION_WELLBEING"}<#Icon iconify="ph:flower-lotus-duotone" class={[@class, @colored && "text-teal-400"]} />
  {#match "MOVEMENTS_POLITICS"}<#Icon iconify="ph:megaphone-duotone" class={[@class, @colored && "text-red-400"]} />
  {#match "MUSIC"}<#Icon iconify="ph:music-notes-duotone" class={[@class, @colored && "text-violet-400"]} />
  {#match "NETWORKING"}<#Icon iconify="ph:handshake-duotone" class={[@class, @colored && "text-blue-400"]} />
  {#match "OUTDOORS_ADVENTURE"}<#Icon iconify="ph:mountains-duotone" class={[@class, @colored && "text-green-400"]} />
  {#match "PARTY"}<#Icon iconify="ph:confetti-duotone" class={[@class, @colored && "text-pink-400"]} />
  {#match "PERFORMING_VISUAL_ARTS"}<#Icon iconify="ph:mask-happy-duotone" class={[@class, @colored && "text-purple-400"]} />
