  {#match "CAUSES"}<#Icon iconify="ph:hand-heart-duotone" class={[@class, @colored && "text-red-400"]} />
  {#match "CLIMATE_ENVIRONMENT"}<#Icon iconify="ph:leaf-duotone" class={[@class, @colored && "text-green-400"]} />
  {#match "COMMUNITY"}<#Icon iconify="ph:users-three-duotone" class={[@class, @colored && "text-sky-400"]} />
  {#match "COMEDY"}<#Icon iconify="ph:smiley-duotone" class={[@class, @colored && "text-yellow-400"]} />
  {#match "CRAFTS"}<#Icon iconify="ph:scissors-duotone" class={[@class, @colored && "text-orange-400"]} />
  {#match "CREATIVE_JAM"}<#Icon iconify="ph:sparkle-duotone" class={[@class, @colored && "text-fuchsia-400"]} />
