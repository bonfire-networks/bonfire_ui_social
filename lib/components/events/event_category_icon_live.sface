  {#match "FILM_MEDIA"}<#Icon iconify="ph:film-slate-duotone" class={[@class, @colored && "text-indigo-400"]} />
  {#match "FOOD_DRINK"}<#Icon iconify="ph:fork-knife-duotone" class={[@class, @colored && "text-amber-400"]} />
  {#match "GAMES"}<#Icon iconify="ph:game-controller-duotone" class={[@class, @colored && "text-cyan-400"]} />
