<div data-id="thread_empty" class="flex flex-col items-center text-center py-10 px-4">
  <#Icon
    iconify="ph:chat-circle-dots-duotone"
    class="size-8 text-base-content/40"
    aria-hidden="true"
  />
  <p class="mt-3 text-base font-semibold text-base-content">{l("No replies yet")}</p>
  <p class="mt-1 max-w-sm text-sm text-base-content/60">{l("Be the first to share your thoughts.")}</p>
</div>
